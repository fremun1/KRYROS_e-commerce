# Compiled output
dist/
build/

# Node modules
node_modules/

# Environment variables — NEVER commit these
.env
.env.*
*.env
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage
coverage/
.nyc_output/

# Test results
test-results/
junit.xml

# TypeScript build info
*.tsbuildinfo
tsconfig.build.tsbuildinfo

# NestJS cache
.nest/
.cache/

# IDE / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Prisma
prisma/*.db
prisma/*.db-journal

# Package manager locks (keep package-lock.json, ignore others)
yarn.lock
pnpm-lock.yaml
