generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                 @id @default(uuid())
  email                    String?                @unique
  password                 String
  firstName                String
  lastName                 String
  phone                    String?                @unique
  avatar                   String?
  role                     UserRole               @default(CUSTOMER)
  isVerified               Boolean                @default(true)
  isActive                 Boolean                @default(true)
  emailVerifiedAt          DateTime?
  lastLoginAt              DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  passwordResetExpires     DateTime?
  passwordResetToken       String?
  twoFactorEnabled         Boolean                @default(false)
  twoFactorSecret          String?
  emailVerificationExpires DateTime?
  emailVerificationToken   String?
  addresses                Address[]
  creditAccounts           CreditAccount[]
  creditApplications       CreditApplication[]
  creditProfile            CreditProfile?
  notifications            Notification[]
  orders                   Order[]
  refreshTokens            RefreshToken[]
  reviews                  Review[]
  serviceBookings          ServiceBooking[]
  supportTickets           SupportTicket[]
  devices                  UserDevice[]
  roleAssignments          UserRoleAssignment[]
  wallet                   Wallet?
  wholesaleAccount         WholesaleAccount?
  wholesaleApplications    WholesaleApplication[]
  wishlists                WishlistItem[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model UserDevice {
  id        String   @id @default(uuid())
  userId    String
  fcmToken  String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@index([createdAt])
  @@map("user_devices")
}

model Role {
  id              String               @id @default(uuid())
  name            String               @unique
  description     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  permissions     Permission[]
  userAssignments UserRoleAssignment[]

  @@map("roles")
}

model Permission {
  id       String @id @default(uuid())
  name     String @unique
  resource String
  action   String
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id])

  @@map("permissions")
}

model UserRoleAssignment {
  id     String @id @default(uuid())
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Address {
  id             String      @id @default(uuid())
  userId         String?
  type           AddressType @default(SHIPPING)
  firstName      String
  lastName       String
  company        String?
  street         String
  city           String?
  state          String?
  country        String      @default("Zambia")
  zipCode        String?
  phone          String
  isDefault      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  cityId         String?
  cityName       String?
  countryId      String?
  manual         Boolean     @default(false)
  stateId        String?
  stateName      String?
  email          String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingOrders  Order[]     @relation("OrderBillingAddress")
  shippingOrders Order[]     @relation("OrderShippingAddress")

  @@index([userId])
  @@map("addresses")
}

model Category {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  image       String?
  icon        String?
  parentId    String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  showOnHome  Boolean      @default(false)
  brands      Brand[]
  parent      Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[]   @relation("CategoryHierarchy")
  creditPlans CreditPlan[]
  products    Product[]

  @@map("categories")
}

model Brand {
  name        String
  slug        String       @unique
  logo        String?
  description String?
  website     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  id          Int          @id @default(autoincrement())
  categoryId  String?
  country     String?
  category    Category?    @relation(fields: [categoryId], references: [id])
  creditPlans CreditPlan[]
  products    Product[]

  @@map("brands")
}

model Product {
  id                     String              @id @default(uuid())
  name                   String
  slug                   String              @unique
  description            String
  shortDescription       String?
  price                  Decimal             @db.Decimal(10, 2)
  salePrice              Decimal?            @db.Decimal(10, 2)
  sku                    String              @unique
  barcode                String?
  weight                 Decimal?            @db.Decimal(10, 3)
  isFeatured             Boolean             @default(false)
  isFlashSale            Boolean             @default(false)
  flashSalePrice         Decimal?            @db.Decimal(10, 2)
  flashSaleEnd           DateTime?
  allowCredit            Boolean             @default(false)
  creditMinimum          Decimal?            @db.Decimal(10, 2)
  metaTitle              String?
  metaDescription        String?
  metaKeywords           String?
  isActive               Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  categoryId             String
  brandId                Int?
  specifications         String?
  creditMessage          String?
  deliveryInfo           String?
  warrantyInfo           String?
  discountPercentage     Int?
  hasFiveYearGuarantee   Boolean             @default(true)
  hasFreeReturns         Boolean             @default(true)
  hasInstallmentOptions  Boolean             @default(true)
  isNew                  Boolean             @default(true)
  rating                 Float?              @default(0)
  reviewCount            Int?                @default(0)
  stockCurrent           Int                 @default(42)
  stockTotal             Int                 @default(50)
  wholesalePrice         Decimal?            @db.Decimal(10, 2)
  fiveYearGuaranteeText  String?
  freeReturnsText        String?
  installmentOptionsText String?
  isWholesaleOnly        Boolean             @default(false)
  unitsPerPack           Int                 @default(1)
  wholesaleMoq           Int                 @default(1)
  fullyTested            Boolean             @default(true)
  fullyTestedText        String?
  isBestSeller           Boolean             @default(false)
  isHot                  Boolean             @default(false)
  isTrending             Boolean             @default(false)
  // New fields for this update
  condition              String?             @default("New") // e.g., New, Used, Refurbished
  shippingFee            Decimal?            @db.Decimal(10, 2)
  shippingTitle          String?
  estimatedDeliveryDays  Int?                @default(3)
  estimatedDeliveryMinDays Int?              @default(2)
  estimatedDeliveryMaxDays Int?              @default(7)
  popularItemText        String?
  easyReturnsText        String?
  creditAccounts         CreditAccount[]
  creditApplications     CreditApplication[]
  inventory              Inventory?
  orderItems             OrderItem[]
  images                 ProductImage[]
  productRelations       ProductRelation[]   @relation("ProductRelation")
  relatedTo              ProductRelation[]   @relation("RelatedTo")
  tags                   ProductTag[]
  variants               ProductVariant[]
  brand                  Brand?              @relation(fields: [brandId], references: [id])
  category               Category            @relation(fields: [categoryId], references: [id])
  reviews                Review[]
  wholesalePrices        WholesalePrice[]
  wishlists              WishlistItem[]

  @@index([name])
  @@index([createdAt])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id         String      @id @default(uuid())
  productId  String
  name       String
  type       VariantType
  value      String
  price      Decimal     @db.Decimal(10, 2)
  stock      Int         @default(0)
  sku        String      @unique
  isActive   Boolean     @default(true)
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model ProductTag {
  id        String  @id @default(uuid())
  productId String
  tag       String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tag])
  @@map("product_tags")
}

model ProductRelation {
  id           String  @id @default(uuid())
  productId    String
  relatedId    String
  relationType String  @default("related")
  product      Product @relation("ProductRelation", fields: [productId], references: [id], onDelete: Cascade)
  related      Product @relation("RelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedId, relationType])
  @@map("product_relations")
}

model Inventory {
  id             String          @id @default(uuid())
  productId      String          @unique
  stock          Int             @default(0)
  reservedStock  Int             @default(0)
  reorderLevel   Int             @default(10)
  isTrackStock   Boolean         @default(true)
  allowBackorder Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements      StockMovement[]

  @@map("inventory")
}

model StockMovement {
  id          String            @id @default(uuid())
  inventoryId String
  type        StockMovementType
  quantity    Int
  reference   String?
  notes       String?
  createdAt   DateTime          @default(now())
  inventory   Inventory         @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

model Review {
  id         String   @id @default(uuid())
  productId  String
  userId     String?
  rating     Int
  title      String?
  comment    String?
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  imageUrl   String?
  isFeatured Boolean  @default(false)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique
  userId            String?
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentReference  String?
  subtotal          Decimal       @db.Decimal(10, 2)
  discount          Decimal       @default(0) @db.Decimal(10, 2)
  tax               Decimal       @default(0) @db.Decimal(10, 2)
  shipping          Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  notes             String?
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  shippingAddressId String?
  billingAddressId  String?
  paymentPhone      String?
  totalZMW          Decimal?      @db.Decimal(10, 2)
  estimatedDays     Int?
  currencyCode      String        @default("USD")
  currencySymbol    String        @default("$")
  exchangeRate      Decimal       @default(1.0) @db.Decimal(18, 6)
  paymentMethod     String?
  items             OrderItem[]
  logs              OrderLog[]
  billingAddress    Address?      @relation("OrderBillingAddress", fields: [billingAddressId], references: [id])
  shippingAddress   Address?      @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  user              User?         @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id        String          @id @default(uuid())
  orderId   String
  productId String
  variantId String?
  quantity  Int
  price     Decimal         @db.Decimal(10, 2)
  total     Decimal         @db.Decimal(10, 2)
  createdAt DateTime        @default(now())
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderLog {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_logs")
}

model WholesaleAccount {
  id            String           @id @default(uuid())
  userId        String           @unique
  companyName   String
  taxId         String?
  address       String?
  contactPerson String?
  discountTier  Int              @default(1)
  status        WholesaleStatus  @default(APPROVED)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  city          String?
  creditLimit   Decimal?         @db.Decimal(10, 2)
  phone         String?
  tierName      String?
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals         WholesaleDeal[]
  prices        WholesalePrice[]

  @@map("wholesale_accounts")
}

model WholesaleApplication {
  id                    String          @id @default(uuid())
  userId                String
  companyName           String
  businessType          String
  registrationNumber    String?
  taxId                 String?
  website               String?
  firstName             String
  lastName              String
  email                 String
  phone                 String
  jobTitle              String
  address               String
  city                  String
  state                 String?
  country               String
  zipCode               String?
  businessPhone         String?
  businessEmail         String?
  annualRevenue         Decimal?        @db.Decimal(15, 2)
  employeeCount         Int?
  productCategories     String?
  estimatedMonthlyOrder Decimal?        @db.Decimal(15, 2)
  description           String?
  status                WholesaleStatus @default(PENDING)
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wholesale_applications")
}

model WholesalePrice {
  id          String            @id @default(uuid())
  productId   String
  accountId   String?
  minQuantity Int
  price       Decimal           @db.Decimal(10, 2)
  account     WholesaleAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, accountId, minQuantity])
  @@map("wholesale_prices")
}

model CreditProfile {
  id              String          @id @default(uuid())
  userId          String          @unique
  creditLimit     Decimal         @default(0) @db.Decimal(10, 2)
  availableCredit Decimal         @default(0) @db.Decimal(10, 2)
  usedCredit      Decimal         @default(0) @db.Decimal(10, 2)
  creditScore     Int             @default(500)
  status          CreditStatus    @default(ACTIVE)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accounts        CreditAccount[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_profiles")
}

model CreditApplication {
  id               String          @id @default(uuid())
  userId           String
  productId        String
  creditPlanId     String
  amount           Decimal         @db.Decimal(10, 2)
  status           CreditAppStatus @default(PENDING)
  firstName        String
  lastName         String
  email            String
  phone            String
  address          String
  city             String
  state            String?
  country          String
  zipCode          String?
  employmentStatus String
  monthlyIncome    Decimal         @db.Decimal(10, 2)
  employerName     String?
  employerPhone    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  creditPlan       CreditPlan      @relation(fields: [creditPlanId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
  user             User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([creditPlanId])
  @@map("credit_applications")
}

model CreditAccount {
  id              String              @id @default(uuid())
  userId          String
  creditProfileId String?
  productId       String
  creditPlanId    String
  amount          Decimal             @db.Decimal(10, 2)
  totalPayable    Decimal             @db.Decimal(10, 2)
  monthlyPayment  Decimal             @db.Decimal(10, 2)
  paidAmount      Decimal             @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal             @db.Decimal(10, 2)
  nextPaymentDate DateTime
  status          CreditAccountStatus @default(ACTIVE)
  startDate       DateTime            @default(now())
  endDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  creditPlan      CreditPlan          @relation(fields: [creditPlanId], references: [id])
  creditProfile   CreditProfile?      @relation(fields: [creditProfileId], references: [id], onDelete: Cascade)
  product         Product             @relation(fields: [productId], references: [id])
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        CreditPayment[]

  @@map("credit_accounts")
}

model CreditPlan {
  id               String              @id @default(uuid())
  name             String
  duration         Int
  interestRate     Decimal             @db.Decimal(5, 2)
  minimumAmount    Decimal             @db.Decimal(10, 2)
  maximumAmount    Decimal             @db.Decimal(10, 2)
  description      String?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  targetBrandId    Int?
  targetCategoryId String?
  accounts         CreditAccount[]
  applications     CreditApplication[]
  brand            Brand?              @relation(fields: [targetBrandId], references: [id])
  category         Category?           @relation(fields: [targetCategoryId], references: [id])

  @@map("credit_plans")
}

model CreditPayment {
  id        String              @id @default(uuid())
  accountId String
  amount    Decimal             @db.Decimal(10, 2)
  dueDate   DateTime
  paidDate  DateTime?
  status    CreditPaymentStatus @default(PENDING)
  penalty   Decimal?            @db.Decimal(10, 2)
  reference String?
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  account   CreditAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("credit_payments")
}

model Wallet {
  id             String        @id @default(uuid())
  userId         String        @unique
  balance        Decimal       @default(0) @db.Decimal(10, 2)
  pendingBalance Decimal       @default(0) @db.Decimal(10, 2)
  currency       String        @default("ZMW")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Transaction {
  id          String            @id @default(uuid())
  walletId    String
  type        TransactionType
  amount      Decimal           @db.Decimal(10, 2)
  description String?
  reference   String            @unique
  status      TransactionStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime          @default(now())
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Service {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  price       Decimal          @db.Decimal(10, 2)
  category    String
  duration    String
  image       String?
  features    String[]
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  bookings    ServiceBooking[]

  @@map("services")
}

model ServiceBooking {
  id            String        @id @default(uuid())
  userId        String
  serviceId     String
  scheduledDate DateTime
  scheduledTime String
  status        BookingStatus @default(PENDING)
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  service       Service       @relation(fields: [serviceId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("service_bookings")
}

model CMSPage {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  content         String?
  metaTitle       String?
  metaDescription String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cms_pages")
}

model CMSBanner {
  id               String    @id @default(uuid())
  title            String
  subtitle         String?
  image            String?
  link             String?
  linkText         String?
  isActive         Boolean   @default(true)
  position         Int       @default(0)
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  mediaType        String    @default("image")
  videoUrl         String?
  duration         Int?
  displayDays      Int?
  badge            String?
  secondaryCta     String?
  secondaryCtaLink String?
  tag              String?

  @@map("cms_banners")
}

model CMSSection {
  id              String   @id @default(uuid())
  type            String
  title           String?
  subtitle        String?
  config          Json?
  isActive        Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  animation       String?
  backgroundColor String?
  description     String?
  imageUrl        String?
  link            String?
  linkText        String?
  pageName        String?
  pageSlug        String?
  textColor       String?

  @@index([pageSlug])
  @@map("cms_sections")
}

model HomePageSection {
  id                 String   @id @default(uuid())
  type               String
  order              Int      @default(0)
  isActive           Boolean  @default(true)
  title              String?
  subtitle           String?
  description        String?
  backgroundColor    String?
  textColor          String?
  imageUrl           String?
  videoUrl           String?
  link               String?
  linkText           String?
  config             Json?
  animation          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  targetCategoryId   String?
  targetCategorySlug String?

  @@map("homepage_sections")
}

model FooterSection {
  id        String       @id @default(uuid())
  title     String
  order     Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  links     FooterLink[]

  @@map("footer_sections")
}

model FooterLink {
  id        String        @id @default(uuid())
  sectionId String
  label     String
  href      String
  order     Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  section   FooterSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("footer_links")
}

model FooterConfig {
  id                       String   @id @default(uuid())
  logo                     String?
  description              String?
  contactPhone             String?
  contactEmail             String?
  contactAddress           String?
  newsletterTitle          String?  @default("Subscribe to our Newsletter")
  newsletterSubtitle       String?
  copyrightText            String?
  socialLinks              Json?
  paymentMethods           Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  announcementBarBgColor   String?  @default("bg-kryros-dark")
  announcementBarEnabled   Boolean  @default(true)
  announcementBarLink      String?
  announcementBarText      String?  @default("30% discount on all products special for November!")
  announcementBarTextColor String?  @default("text-kryros-green")
  newsletterPopupDelay     Int?     @default(3000)
  newsletterPopupEnabled   Boolean  @default(true)
  newsletterPopupImage     String?
  newsletterPopupSubtitle  String?
  newsletterPopupTitle     String?  @default("Unlock Premium Deals")

  @@map("footer_config")
}

model CMSSiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_site_configs")
}

model CMSBrandBanner {
  id          String   @id @default(uuid())
  brandSlug   String   @unique
  brandName   String
  tagline     String?
  description String?
  bgColor     String?
  bgGradient  String?
  imageUrl    String?
  ctaText     String   @default("Shop Now")
  ctaLink     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cms_brand_banners")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String?
  title       String
  message     String
  data        Json?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  orderIds    String[]
  scheduledAt DateTime?
  sent        Boolean   @default(false)
  targetType  String    @default("SINGLE")
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SupportTicket {
  id          String          @id @default(uuid())
  userId      String
  subject     String
  description String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  userId     String
  message    String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter")
}

model ShippingMethod {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  fee           Decimal  @db.Decimal(10, 2)
  minThreshold  Decimal  @default(0) @db.Decimal(10, 2)
  estimatedDays String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sortOrder     Int      @default(0)

  @@map("shipping_methods")
}

model Country {
  id              String                 @id @default(uuid())
  name            String                 @unique
  code            String                 @unique
  currencyCode    String
  currencySymbol  String
  symbolPosition  SymbolPosition         @default(BEFORE)
  exchangeRate    Decimal                @default(1.0) @db.Decimal(18, 6)
  autoRate        Boolean                @default(true)
  lastRateUpdate  DateTime?
  flag            String?
  status          Boolean                @default(true)
  isDefault       Boolean                @default(false)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  shippingEnabled Boolean                @default(true)
  paymentMethods  CountryPaymentMethod[]
  shippingZones   ShippingZone[]
  states          State[]

  @@map("countries")
}

model State {
  id            String         @id @default(uuid())
  countryId     String
  name          String
  code          String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cities        City[]
  shippingZones ShippingZone[]
  country       Country        @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, name])
  @@map("states")
}

model City {
  id            String         @id @default(uuid())
  stateId       String
  name          String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  state         State          @relation(fields: [stateId], references: [id], onDelete: Cascade)
  shippingZones ShippingZone[]

  @@unique([stateId, name])
  @@map("cities")
}

model ShippingZone {
  id              String                   @id @default(uuid())
  name            String                   @unique
  countryId       String?
  stateId         String?
  cityId          String?
  priority        Int                      @default(0)
  isActive        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  minOrder        Decimal?                 @db.Decimal(10, 2)
  rate            Decimal?                 @db.Decimal(10, 2)
  region          String?
  shippingMethod  String?
  shippingMethods LocationShippingMethod[]
  city            City?                    @relation(fields: [cityId], references: [id])
  country         Country?                 @relation(fields: [countryId], references: [id])
  state           State?                   @relation(fields: [stateId], references: [id])

  @@map("shipping_zones")
}

model LocationShippingMethod {
  id                    String       @id @default(uuid())
  zoneId                String
  name                  String
  price                 Decimal      @default(0) @db.Decimal(10, 2)
  freeShippingThreshold Decimal?     @db.Decimal(10, 2)
  estimatedDays         String?
  status                Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  sortOrder             Int          @default(0)
  cost                  Decimal      @default(0) @db.Decimal(10, 2)
  description           String?
  isActive              Boolean      @default(true)
  minOrderAmount        Decimal?     @db.Decimal(10, 2)
  type                  String       @default("FLAT")
  zone                  ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("location_shipping_methods")
}

model CountryPaymentMethod {
  id              String        @id @default(uuid())
  countryId       String
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paymentMethodId String
  country         Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([countryId, paymentMethodId])
  @@map("country_payment_methods")
}

model PaymentMethod {
  id             String                 @id @default(uuid())
  name           String                 @unique
  code           String                 @unique
  description    String?
  icon           String?
  config         Json?
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  countryMethods CountryPaymentMethod[]

  @@map("payment_methods")
}

model PickupStation {
  id           String   @id @default(uuid())
  name         String
  address      String
  city         String
  state        String?
  country      String   @default("Zambia")
  latitude     Float?
  longitude    Float?
  phone        String?
  email        String?
  openingHours String?
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  image        String?

  @@map("pickup_stations")
}

model WholesaleDeal {
  id          String            @id @default(uuid())
  accountId   String?
  title       String
  description String?
  discount    Decimal?          @db.Decimal(5, 2)
  minOrder    Decimal?          @db.Decimal(10, 2)
  validUntil  DateTime?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  account     WholesaleAccount? @relation(fields: [accountId], references: [id])

  @@map("wholesale_deals")
}

model CheckoutMethod {
  id        String             @id @default(uuid())
  name      String
  type      String
  icon      String?
  sortOrder Int                @default(0)
  isEnabled Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  providers CheckoutProvider[]

  @@map("checkout_methods")
}

model CheckoutProvider {
  id               String            @id @default(uuid())
  checkoutMethodId String
  name             String
  description      String?
  sortOrder        Int               @default(0)
  isEnabled        Boolean           @default(true)
  config           Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  networks         CheckoutNetwork[]
  checkoutMethod   CheckoutMethod    @relation(fields: [checkoutMethodId], references: [id], onDelete: Cascade)

  @@map("checkout_providers")
}

model CheckoutNetwork {
  id         String           @id @default(uuid())
  providerId String
  name       String
  sortOrder  Int              @default(0)
  isEnabled  Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  provider   CheckoutProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("checkout_networks")
}

model SmsContact {
  id        String   @id @default(uuid())
  name      String?
  phone     String   @unique
  source    String   @default("Manual")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@map("sms_contacts")
}

model EmailContact {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  source    String   @default("Manual")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("email_contacts")
}

model SmsSupportedCountry {
  id        String   @id @default(uuid())
  name      String
  dialCode  String   @unique
  isoCode   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sms_supported_countries")
}

